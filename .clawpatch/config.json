{
  "schemaVersion": 1,
  "stateDir": ".clawpatch",
  "include": [
    "**/*"
  ],
  "exclude": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "target/**",
    ".build/**",
    ".git/**",
    ".clawpatch/**",
    ".serena/**",
    ".claude/**",
    ".swiftpm/**",
    ".screenshots/**",
    "images/**",
    ".design-handoff/**",
    ".design-handoff 2/**",
    ".design-handoff 3/**",
    ".missions/**",
    "TranscriberApp/.dd/**",
    "TranscriberApp/.dd-release/**",
    "**/Build/Intermediates.noindex/**",
    "**/Build/Intermediates/**",
    "**/DerivedSources/**",
    "**/.DS_Store"
  ],
  "provider": {
    "name": "codex",
    "model": null,
    "reasoningEffort": null
  },
  "commands": {
    "typecheck": "swift build",
    "lint": null,
    "format": null,
    "test": "swift test"
  },
  "review": {
    "maxContextFiles": 24,
    "maxOwnedFiles": 12,
    "maxFindingsPerFeature": 10,
    "minConfidenceToFix": "medium"
  },
  "git": {
    "requireCleanWorktreeForFix": true,
    "commit": false,
    "openPr": false
  }
}
