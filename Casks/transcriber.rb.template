# Phase τ: Homebrew cask template. scripts/release.sh substitutes
# {{VERSION}} and {{SHA256}} at release time and emits a concrete
# `transcriber.rb` ready to publish to the user's tap.
#
# Usage at release time:
#   sed -e "s/{{VERSION}}/1.0.0-rc1/g" \\
#       -e "s/{{SHA256}}/$(shasum -a 256 build/Transcriber-1.0.0-rc1.dmg | cut -d' ' -f1)/" \\
#       Casks/transcriber.rb.template > <tap>/Casks/transcriber.rb
#
# The tap repo lives outside this project — typically
# `<github-user>/homebrew-tap` with a `Casks/` directory.

cask "transcriber" do
  version "{{VERSION}}"
  sha256  "{{SHA256}}"

  url "https://releases.transcriber.app/v#{version}/Transcriber-#{version}.dmg"
  name "Transcriber"
  desc "Menu-bar meeting transcriber for macOS"
  homepage "https://github.com/szymonsypniewicz/transcriber"

  livecheck do
    url :url
    strategy :extract_plist
  end

  depends_on macos: ">= :sequoia"

  app "TranscriberApp.app", target: "Transcriber.app"

  # Spec § Privacy: clean up Keychain entries on cask uninstall via
  # zap. Settings + Logs are preserved unless the user explicitly
  # uninstalls with `--zap`.
  zap trash: [
    "~/Library/Logs/TranscriberApp",
    "~/Library/Preferences/com.szymonsypniewicz.transcriber.plist",
    "~/Library/Application Support/com.szymonsypniewicz.transcriber",
  ],
      delete: [
        # Keychain wipe — requires the user to confirm via macOS auth.
        "/usr/bin/security delete-generic-password -a claude -s elevenlabs-api-key",
        "/usr/bin/security delete-generic-password -a claude -s diagnostics-instance-id",
      ]
end
